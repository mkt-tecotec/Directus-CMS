# Directus CMS - Environment Variables Template
# Copy file này thành .env và điền giá trị thật
# KHÔNG commit file .env lên Git

# ── Directus Core ──────────────────────────────────────
SECRET=replace-with-openssl-rand-hex-32
PUBLIC_URL=https://cms.tecotec.top

# ── Database (PostgreSQL) ───────────────────────────────
DB_USER=directus
DB_PASSWORD=replace-with-strong-password
DB_DATABASE=directus

# ── Admin Account (xóa sau lần đăng nhập đầu) ──────────
ADMIN_EMAIL=admin@tecotec.vn
ADMIN_PASSWORD=replace-with-strong-password

# ── CORS ───────────────────────────────────────────────
# Danh sách domain được phép gọi API, cách nhau bằng dấu phẩy
CORS_ORIGIN=https://tecotec.vn,https://n8n.tecotec.top
