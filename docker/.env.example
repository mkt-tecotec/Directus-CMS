# TECOTEC Directus CMS - Environment Variables
# Copy thành .env và điền giá trị thực. KHÔNG commit file .env

# PostgreSQL
POSTGRES_USER=directus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=directus

# Directus core - tạo SECRET: openssl rand -hex 32
SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING

# Database connection
DB_CLIENT=pg
DB_HOST=database
DB_PORT=5432
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS=redis://cache:6379

# Public URL
PUBLIC_URL=https://cms.tecotec.top

# Admin (chỉ dùng lần đầu - có thể xóa sau khi đăng nhập)
ADMIN_EMAIL=admin@tecotec.vn
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Rate limiting
RATE_LIMITER_ENABLED=true
RATE_LIMITER_STORE=redis
RATE_LIMITER_POINTS=100
RATE_LIMITER_DURATION=1

# CORS
CORS_ENABLED=true
CORS_ORIGIN=true

# Storage
STORAGE_LOCATIONS=local
STORAGE_LOCAL_ROOT=./uploads

# Logging
LOG_LEVEL=warn
LOG_STYLE=pretty

# Email (tùy chọn)
# EMAIL_FROM=cms@tecotec.vn
# EMAIL_TRANSPORT=smtp
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=cms@tecotec.vn
# EMAIL_SMTP_PASSWORD=APP_PASSWORD
